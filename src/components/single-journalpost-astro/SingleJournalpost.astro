---
import type { Language } from "@language/language";
import { getOboToken } from "@utils/server/token";
import { getJournalpostUrl, dokumentUrl } from "@src/urls";
import { format } from "date-fns";
import { setAvsenderMottaker } from "@utils/client/setAvsenderMottaker";

interface Props {
  journalpostId: string;
}

const { journalpostId } = Astro.props;
const language = Astro.currentLocale as Language;

const journalpostUrl = getJournalpostUrl(journalpostId);

const oboToken = await getOboToken(Astro.locals.token);
let isError = false;

const journalpost = await fetch(journalpostUrl, {
  method: "GET",
  headers: {
    "Content-Type": "application/json",
    Accept: "application/json",
    Authorization: `Bearer ${oboToken}`,
  },
})
  .then((response) => {
    if (!response.ok) {
      console.error(`Error, fetch failed with status: ${response.status}`);
      isError = true;
    }

    return response.json();
  })
  .catch((error) => {
    console.error(`Error, fetch failed: ${error}`);
    isError = true;
  });

  const hovedDokumentUrl = `${dokumentUrl}/${journalpostId}/${journalpost.dokument.dokumentInfoId}`;
  const avsenderText = setAvsenderMottaker(journalpost);
  const dato = format(new Date(journalpost.opprettet), "dd.MM.yyyy");
  const veddleggsListe = journalpost.vedlegg;
---


