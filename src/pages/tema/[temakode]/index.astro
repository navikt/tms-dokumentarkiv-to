---
import FeilMelding from "@components/feilmelding/Feilmelding";
import Filters from "@components/filters/Filters";
import Journalpostliste from "@components/journalpostliste/Journalpostliste";
import PageHeader from "@components/pageHeader/PageHeader.astro";
import SelectFullmakt from "@components/representasjon/SelectFullmakt";
import type { Language } from "@language/language";
import { text } from "@language/text";
import Layout from "@layouts/Layout.astro";
import { Heading } from "@navikt/ds-react";
import { minSideUrlWithLanguage } from "@src/urls";

const language = Astro.currentLocale as Language;
const params = Astro.params;
const tema = params.temakode ? params.temakode : null;
---

<Layout title="Dokumenter - nav.no" language={language}>
  <FeilMelding language={language} client:only="react" />
  <PageHeader
    description={text.dokumenterIngress[language]}
    breadcrumbItems={[
      {label: text.minSide[language], href: minSideUrlWithLanguage[language]},
    ]}
  >
    <Heading level="1" size="large">
      {text.dokumenter[language]}
    </Heading>
  </PageHeader>
  <SelectFullmakt language={language} client:only="react" />
  <Filters language={language} queryParam={tema} client:only="react" />
  <Journalpostliste language={language} client:only="react" />
</Layout>
