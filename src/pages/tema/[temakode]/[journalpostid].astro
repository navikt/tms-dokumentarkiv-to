---
import SingleJournalpost from "@components/single-journalpost/SingleJournalpost";
import Layout from "@layouts/Layout.astro";
import type {Language} from "@language/language";
import FeilMelding from "@components/feilmelding/Feilmelding";
import Breadcrumbs from "@components/breadcrumbs/Breadcrumbs";

const {journalpostid, temakode} = Astro.params;
const params = Astro.url.searchParams;
const fullmakt = params.get("fullmakt");
const language = Astro.currentLocale as Language;
const languageSelectorUrl = `/tema/${temakode}/${journalpostid}`;
---

<Layout title="Dokumentdetaljer - nav.no" language={language} languageSelectorUrl={languageSelectorUrl}>
  <Breadcrumbs showDokumenter={true} language={language} client:only="react" />
  <FeilMelding language={language} client:only="react" />
  <SingleJournalpost
    language={language}
    journalpostId={journalpostid}
    temakode={temakode}
    fullmakt={fullmakt}
    client:only="react"
  />
</Layout>
